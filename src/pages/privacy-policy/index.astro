---
import Layout from '../../layouts/Layout.astro';
import PrivacyPolicyApp from '../../components/PrivacyPolicyApp.tsx';
---

<Layout 
	title="Политика конфиденциальности — Центр Побед"
	description="Ознакомьтесь с политикой конфиденциальности оздоровительного центра Центр Побед. Мы заботимся о безопасности ваших персональных данных."
	noindex={true}
	schema={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "BreadcrumbList",
				"itemListElement": [
					{
						"@type": "ListItem",
						"position": 1,
						"name": "Главная",
						"item": "https://centrpobed.kz/"
					},
					{
						"@type": "ListItem",
						"position": 2,
						"name": "Политика конфиденциальности",
						"item": "https://centrpobed.kz/privacy-policy"
					}
				]
			}
		]
	})}
>
	<PrivacyPolicyApp client:load />
</Layout>
