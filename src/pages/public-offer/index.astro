---
import Layout from '../../layouts/Layout.astro';
import PublicOfferApp from '../../components/PublicOfferApp.tsx';
---

<Layout 
	title="Публичная оферта — Центр Побед"
	description="Публичный договор возмездного оказания услуг оздоровительного центра Центр Побед. Информация о правах и обязанностях сторон."
	noindex={true}
	schema={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "BreadcrumbList",
				"itemListElement": [
					{
						"@type": "ListItem",
						"position": 1,
						"name": "Главная",
						"item": "https://centrpobed.kz/"
					},
					{
						"@type": "ListItem",
						"position": 2,
						"name": "Публичная оферта",
						"item": "https://centrpobed.kz/public-offer"
					}
				]
			}
		]
	})}
>
	<PublicOfferApp client:load />
</Layout>
