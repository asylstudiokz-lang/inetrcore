---
import '../styles/index.css';
import '../styles/fonts.css';

interface Props {
	title: string;
	description?: string;
	noindex?: boolean;
	schema?: string;
	canonicalURL?: string;
	keywords?: string;
	ogImage?: string;
}

const { 
	title, 
	description = "Центр Побед — Инновационный Оздоровительный Центр в Алматы. Остеопатия, коррекция прикуса Миката, лечение ран ЖКИМ и восстановление при ЗПРР.",
	noindex = false,
	schema,
	canonicalURL,
	keywords = "оздоровительный центр, Алматы, остеопатия, ЗПРР, ЗРР, коррекция прикуса, Миката, ЖКИМ, лечение ран, витамины, нутриенты",
	ogImage = "https://intercore-intech.com/logo.webp"
} = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		{noindex ? (
			<meta name="robots" content="noindex, nofollow" />
		) : (
			<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		)}
		<link rel="canonical" href={canonicalURL || Astro.url.href} />
		<link rel="publisher" href="https://intercore-intech.com" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL || Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL || Astro.url.href} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />

		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		{schema && <script type="application/ld+json" set:html={schema} />}
	</head>
	<body class="bg-[#f2fcf8]">
		<slot />
	</body>
</html>
