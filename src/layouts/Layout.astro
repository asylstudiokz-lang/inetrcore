---
import '../styles/index.css';
import '../styles/fonts.css';

interface Props {
	title: string;
	description?: string;
	noindex?: boolean;
	schema?: string;
}

const { 
	title, 
	description = "Центр Побед — Инновационный Оздоровительный Центр в Алматы. Остеопатия, коррекция прикуса Миката, лечение ран ЖКИМ и восстановление при ЗПРР.",
	noindex = false,
	schema
} = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		{schema && <script type="application/ld+json" set:html={schema} />}
	</head>
	<body class="bg-[#f2fcf8]">
		<slot />
	</body>
</html>
