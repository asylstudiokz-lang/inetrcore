---
import '../styles/index.css';
import '../styles/fonts.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Центр Побед — Инновационный Оздоровительный Центр в Алматы. Остеопатия, коррекция прикуса Миката, лечение ран ЖКИМ и восстановление при ЗПРР." } = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-[#f2fcf8]">
		<slot />
	</body>
</html>
